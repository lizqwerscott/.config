#!/bin/bash

set -e

# ============================================
# Helper
# ============================================
info()  { echo -e "\n\033[1;34m==>\033[0m \033[1m$1\033[0m"; }
ask()   { echo -en "\033[1;33m??\033[0m $1 [Y/n] "; read -r; [[ -z "$REPLY" || "$REPLY" =~ ^[Yy]$ ]]; }
done_section() { echo -e "  \033[1;32m✓\033[0m Done.\n"; }

# Ask whether to continue to next component (used in all-install mode)
ask_next() {
  local name="$1"
  echo -en "\033[1;33m??\033[0m Continue installing \033[1m$name\033[0m? [Y/n] "
  read -r
  if [[ -n "$REPLY" && ! "$REPLY" =~ ^[Yy]$ ]]; then
    echo -e "  \033[1;33mSkipping $name.\033[0m\n"
    return 1
  fi
  return 0
}

# ============================================
# 0. System update & base config
# ============================================
install_base() {
  info "System update and base config"
  sudo pacman -Syu
  sudo pacman -S --noconfirm ntfs-3g
  sudo pacman -S --noconfirm archlinuxcn-keyring
  sudo pacman -S --noconfirm yay
  done_section
}

# ============================================
# 1. Desktop environment + wallpaper + screenshot
# ============================================
install_desktop_env() {
  info "Desktop environment (Xorg + bspwm + wallpaper + screenshot)"
  sudo pacman -S --noconfirm \
    xorg bspwm sxhkd polybar picom dunst \
    xdg-desktop-portal networkmanager network-manager-applet \
    mpv xwinwrap feh flameshot maim xclip
  done_section
}

# ============================================
# 2. Terminal & launcher & browser
# ============================================
install_term_browser() {
  info "Terminal, launcher & browser"
  sudo pacman -S --noconfirm kitty ghostty rofi firefox
  done_section
}

# ============================================
# 3. Input method (Fcitx5)
# ============================================
install_input_method() {
  info "Input method (Fcitx5)"
  sudo pacman -S --noconfirm \
    fcitx5 fcitx5-chinese-addons \
    fcitx5-gtk fcitx5-qt fcitx5-configtool
  done_section
}

# ============================================
# 4. Audio (PulseAudio)
# ============================================
install_audio() {
  info "PulseAudio"
  yay -S --noconfirm pulseaudio pavucontrol
  done_section
}

# ============================================
# 5. Mount utilities
# ============================================
install_mount() {
  info "Mount utilities"
  sudo pacman -S --noconfirm udisks2 udiskie
  done_section
}

# ============================================
# 6. NVIDIA drivers
# ============================================
install_nvidia() {
  info "NVIDIA drivers"
  sudo pacman -S --noconfirm nvidia nvidia-settings nvidia-utils nvidia-prime
  done_section
}

# ============================================
# 7. Fonts
# ============================================
install_fonts() {
  info "Fonts"
  yay -S --noconfirm \
    adobe-source-code-pro-font \
    adobe-source-han-serif-cn-fonts \
    ttf-lxgw-neo-xihei-screen-full \
    ttf-lxgw-wenkai-screen \
    wqy-zenhei \
    ttf-jetbrains-mono \
    noto-fonts noto-fonts-cjk noto-fonts-emoji noto-fonts-extra
  done_section
}

# ============================================
# 8. Optional: Clash
# ============================================
install_clash() {
  info "Clash (AUR)"
  yay -S --noconfirm clash-verge-rev-bin
  done_section
}

# ============================================
# 9. Hyprland
# ============================================
install_hyprland() {
  info "Hyprland (Wayland compositor)"
  sudo pacman -S --noconfirm \
    hyprland waybar hyprpaper hyprshutdown hyprcursor \
    swaync \
    xdg-desktop-portal-hyprland
  done_section
}

# ============================================
# Desktop environment chooser
# ============================================
choose_and_install_desktop() {
  echo -e "\033[1;36m--- Select Desktop Environment ---\033[0m"
  echo "  1) Hyprland (Wayland)"
  echo "  2) Xorg + bspwm"
  echo -en "\033[1;33m??\033[0m Enter number [1-2] (default: 1): "
  read -r de_choice
  case "${de_choice:-1}" in
    1) install_hyprland ;;
    2) install_desktop_env ;;
    *) install_hyprland ;;
  esac
}

# ============================================
# Main menu — install_base always runs
# ============================================
sudo pacman -Syu &&

echo -e "\033[1;36m═══════════════════════════════════════\033[0m"
echo -e "\033[1;36m      Arch Linux Install Menu\033[0m"
echo -e "\033[1;36m═══════════════════════════════════════\033[0m"
echo ""
echo "  0) Install all (all components in sequence)"
echo "  1) Desktop environment (Hyprland or Xorg/bspwm)"
echo "  2) Terminal / Launcher / Browser (kitty, rofi, firefox)"
echo "  3) Input method (Fcitx5)"
echo "  4) Audio (PulseAudio)"
echo "  5) Mount utilities (udisks2, udiskie)"
echo "  6) NVIDIA driver"
echo "  7) Fonts"
echo "  8) Clash"
echo "  9) Exit"
echo ""
echo -en "\033[1;33m??\033[0m Enter number (default: 0): "
read -r choice

echo ""
case "${choice:-0}" in
  0)
    install_base
    choose_and_install_desktop
    ask_next "Terminal / Launcher / Browser" && install_term_browser
    ask_next "Input method (Fcitx5)" && install_input_method
    ask_next "Audio (PulseAudio)" && install_audio
    ask_next "Mount utilities" && install_mount
    ask_next "NVIDIA driver" && install_nvidia
    ask_next "Fonts" && install_fonts
    ask_next "Clash" && install_clash
    ;;
  1) choose_and_install_desktop ;;
  2) install_term_browser ;;
  3) install_input_method ;;
  4) install_audio ;;
  5) install_mount ;;
  6) install_nvidia ;;
  7) install_fonts ;;
  8) install_clash ;;
  9)
    echo -e "\033[1;33mExiting installer.\033[0m"
    exit 0
    ;;
  *)
    echo -e "\033[1;31mInvalid input, exiting.\033[0m"
    exit 1
    ;;
esac

echo -e "\n\033[1;32m═══════════════════════════════════════\033[0m"
echo -e "\033[1;32m  Installation complete!\033[0m"
echo -e "\033[1;32m═══════════════════════════════════════\033[0m"

